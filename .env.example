# Ratatoskr first-run configuration
#
# Copy this file to .env and fill only these required values for the
# Telegram bot + OpenRouter quickstart. Optional scraper, YouTube, Twitter/X,
# MCP, monitoring, and provider tuning belong in ratatoskr.yaml; see
# docs/reference/config-file.md.

# Telegram API credentials: https://my.telegram.org/apps
API_ID=123456
API_HASH=replace_with_telegram_api_hash

# BotFather token: https://t.me/BotFather
BOT_TOKEN=1234567890:replace_with_botfather_token_secret

# Comma-separated Telegram user IDs allowed to use this single-user instance.
ALLOWED_USER_IDS=123456789

# PostgreSQL 16. POSTGRES_PASSWORD is required by Docker Compose and has no
# default. DATABASE_URL must use this format, with password characters
# URL-encoded when needed:
# postgresql+asyncpg://ratatoskr_app:<password>@postgres:5432/ratatoskr
POSTGRES_PASSWORD=
DATABASE_URL=

# Internal Redis (Taskiq queue/lock state) auth is opt-in and defaults to
# empty (no auth -- current behavior, non-breaking). Set REDIS_PASSWORD to
# require auth on the internal-only `redis` compose service; when set, every
# consumer's REDIS_URL must also include it: redis://:PASSWORD@redis:6379/...
# REDIS_PASSWORD=

# Primary LLM provider. OpenRouter remains the default quickstart path.
OPENROUTER_API_KEY=sk-or-replace_with_openrouter_key

# Optional, only when web/API/browser-extension JWT auth is enabled:
# JWT_SECRET_KEY=<generate with: openssl rand -hex 32>
#
# Optional client allowlist for web/API/browser-extension auth:
# ALLOWED_CLIENT_IDS=web-v1,browser-extension

# ---------------------------------------------------------------------------
# Search, GitHub repository indexing, and vector sync (optional)
# Full references:
# - docs/guides/setup-qdrant-vector-search.md
# - docs/explanation/github-repository-ingestion.md
# ---------------------------------------------------------------------------

# QDRANT_URL=http://localhost:6333
# QDRANT_REQUIRED=false
# EMBEDDING_PROVIDER=local              # local | gemini
# GEMINI_API_KEY=
# GITHUB_TOKEN_ENCRYPTION_KEY=<generate with: python tools/scripts/generate_github_encryption_key.py>
# VECTOR_RECONCILE_ENABLED=true

# ---------------------------------------------------------------------------
# Scrapers (self-hosted)
# Non-secret defaults live in config/ratatoskr.yaml. Uncomment environment
# overrides only when this deployment must differ from that YAML.
# Full reference: docs/reference/environment-variables.md#multi-provider-scraper-chain
# ---------------------------------------------------------------------------

# Master switches
# SCRAPER_ENABLED=true
# SCRAPER_PROFILE=balanced          # fast | balanced | robust
# SCRAPER_BROWSER_ENABLED=true
# SCRAPER_MIN_CONTENT_LENGTH=400

# Default provider order (13 positions; unsupported/disabled providers skip):
# SCRAPER_PROVIDER_ORDER=["reddit","hn","scrapling","direct_pdf","crawl4ai","firecrawl","defuddle","cloakbrowser","playwright","crawlee","direct_html","scrapegraph_ai","webwright"]

# Scrapling (in-process, no external service needed)
# SCRAPER_SCRAPLING_ENABLED=true
# SCRAPER_SCRAPLING_TIMEOUT_SEC=30

# Crawl4AI (self-hosted Docker sidecar)
# SCRAPER_CRAWL4AI_ENABLED=true
# SCRAPER_CRAWL4AI_URL=http://crawl4ai:11235
# SCRAPER_CRAWL4AI_TOKEN=
# SCRAPER_CRAWL4AI_TIMEOUT_SEC=60
# Crawl4AI cache mode: ENABLED, DISABLED, BYPASS (default), READ_ONLY, WRITE_ONLY
# SCRAPER_CRAWL4AI_CACHE_MODE=BYPASS

# Firecrawl (self-hosted only — cloud Firecrawl is no longer used by the scraper chain)
# FIRECRAWL_SELF_HOSTED_ENABLED=false
# FIRECRAWL_SELF_HOSTED_URL=http://firecrawl-api:3002
# FIRECRAWL_SELF_HOSTED_API_KEY=fc-ratatoskr-local

# Defuddle (self-hosted Docker Compose service; enabled by default)
# SCRAPER_DEFUDDLE_ENABLED=true
# SCRAPER_DEFUDDLE_TIMEOUT_SEC=20
# SCRAPER_DEFUDDLE_API_BASE_URL=http://defuddle-api:3003

# Playwright browser fallback
# SCRAPER_PLAYWRIGHT_ENABLED=true
# SCRAPER_PLAYWRIGHT_TIMEOUT_SEC=30
# Browserforge fingerprint mode for Playwright provider — slim=true uses smaller, lower-overhead fingerprints
# SCRAPER_PLAYWRIGHT_FINGERPRINT_SLIM=false

# Crawlee advanced fallback
# SCRAPER_CRAWLEE_ENABLED=true
# SCRAPER_CRAWLEE_TIMEOUT_SEC=45

# Direct HTML lightweight fallback
# SCRAPER_DIRECT_HTML_ENABLED=true
# SCRAPER_DIRECT_HTML_TIMEOUT_SEC=30

# ScrapeGraph-AI last-resort LLM-driven provider (requires: pip install scrapegraphai)
# SCRAPER_SCRAPEGRAPH_ENABLED=true
# SCRAPER_SCRAPEGRAPH_TIMEOUT_SEC=90

# ---------------------------------------------------------------------------
# Email delivery sink (optional)
# Full reference: docs/reference/environment-variables.md#email-delivery
# ---------------------------------------------------------------------------

# EMAIL_PROVIDER=none                 # none | smtp | resend
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=Ratatoskr
# EMAIL_VERIFICATION_BASE_URL=https://app.example.com/web/settings/email/verify
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# Passwordless and Apple Sign-In auth providers (optional)
# ---------------------------------------------------------------------------

# MAGIC_LINK_VERIFY_URL=https://app.example.com/v1/auth/magic-link/verify
# APPLE_SIGNIN_CLIENT_ID=com.example.ratatoskr
# APPLE_SIGNIN_TEAM_ID=

# ---------------------------------------------------------------------------
# OpenTelemetry distributed tracing (optional — requires [otel] extra)
# Traces flow to Grafana Tempo via OTLP gRPC. Set OTEL_ENABLED=true to activate.
# Full reference: docs/reference/environment-variables.md#opentelemetry
# ---------------------------------------------------------------------------

# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
# OTEL_DB_SESSION_SPANS_ENABLED=false
# RATATOSKR_PROCESS_ROLE=api          # api | bot | worker | scheduler | mcp

# ---------------------------------------------------------------------------
# Monitoring alert delivery (required when RATATOSKR_ENV=production and the
# with-monitoring profile is enabled)
# ---------------------------------------------------------------------------

# Configure one or more real receivers. Slack and Telegram webhook URLs must
# use HTTPS. Keep receiver credentials in the deployment secret environment,
# not in this tracked example file or logs.
# ALERT_WEBHOOK_URL=
# ALERT_SLACK_API_URL=
# ALERT_TELEGRAM_WEBHOOK_URL=
# ALERT_PAGERDUTY_ROUTING_KEY=
