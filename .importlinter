# Layering contracts for the app/ package (epic: restore-architecture-layering).
#
# Enforcement is staged. GREEN contracts are gated in CI (the build fails on any
# regression); BROKEN ones run in advisory mode (reported, non-blocking) as a
# live, shrinking tracker. Promote each to gating once its task lands and it goes
# green:
#   * domain-independence             -> GATING (always green)
#   * infrastructure-no-api           -> GATING (green via remove-infrastructure-dependency-on-api-session-manager, A2)
#   * content-no-telegram             -> GATING (green via break-circular-import-cycles, A3: content no longer imports telegram)
#   * application-no-outward          -> advisory; fix-inner-layer-dependency-direction-leaks (A1) + service deps
#   * tasks-no-api                    -> advisory; break-circular-import-cycles-and-drop-plc0415-suppression (A3)
[importlinter]
root_package = app

[importlinter:contract:domain-independence]
name = domain must not import outer layers
type = forbidden
source_modules =
    app.domain
forbidden_modules =
    app.api
    app.adapters
    app.infrastructure
    app.tasks
    app.di

[importlinter:contract:application-no-outward]
name = application must not import adapters or api
type = forbidden
source_modules =
    app.application
forbidden_modules =
    app.api
    app.adapters

[importlinter:contract:infrastructure-no-api]
name = infrastructure must not import api
type = forbidden
source_modules =
    app.infrastructure
forbidden_modules =
    app.api

[importlinter:contract:tasks-no-api]
name = tasks must not import api
type = forbidden
source_modules =
    app.tasks
forbidden_modules =
    app.api

[importlinter:contract:content-no-telegram]
name = adapters.content must not import adapters.telegram
# Breaks the content <-> telegram import cycle. telegram -> content is legitimate
# (the bot orchestrates content processing), so the rule is one-directional:
# content (the processing engine) must never depend on the telegram delivery
# adapter. Modeled as `forbidden` rather than `independence` for exactly that
# reason.
type = forbidden
source_modules =
    app.adapters.content
forbidden_modules =
    app.adapters.telegram
