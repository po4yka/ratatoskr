      "gridPos": {"h": 5, "w": 12, "x": 12, "y": 1}, "id": 3,
      "options": {"colorMode": "background", "graphMode": "none", "justifyMode": "auto", "orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max by (component) (ratatoskr_status_component_state)", "legendFormat": "{{component}}", "refId": "A"}],
      "title": "Public status components", "type": "stat"
